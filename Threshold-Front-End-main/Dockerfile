FROM node:18 as build
WORKDIR /app

COPY package.json yarn.lock ./

RUN yarn

COPY . ./

ENV NODE_OPTIONS=--max-old-space-size=4096
ARG REACT_APP_BACKEND_API_ENDPOINT
ARG REACT_APP_FIREBASE_API_KEY
ARG REACT_APP_FIREBASE_APP_ID
ARG REACT_APP_FIREBASE_AUTH_DOMAIN
ARG REACT_APP_FIREBASE_MEASUREMENT_ID
ARG REACT_APP_FIREBASE_MESSAGING_SENDER_ID
ARG REACT_APP_FIREBASE_PROJECT_ID
ARG REACT_APP_FIREBASE_STORAGE_BUCKET
ARG REACT_APP_FIREBASE_VAPID_KEY
ARG REACT_APP_REPLAYS_ON_ERROR_SAMPLE_RATE
ARG REACT_APP_REPLAYS_SESSION_SAMPLE_RATE
ARG REACT_APP_SENTRY_DSN
ARG REACT_APP_SENTRY_TRACING_ORIGINS
ARG REACT_APP_TIME_ZONE
ARG REACT_APP_TRACES_SAMPLE_RATE

RUN yarn build

FROM nginx:stable-alpine
COPY --from=build /app/build /usr/share/nginx/html

RUN mkdir -p /etc/nginx/conf.d
COPY conf.d/default.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]